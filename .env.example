# Zoo Management System — environment template
# Copy to ".env" and adjust for your environment. Never commit a real ".env".

# --- Database ---------------------------------------------------------------
# SQLite is fine for local development. Use PostgreSQL for production, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/zoo
DATABASE_URL=sqlite:///./zoo.db

# PostgreSQL connection pool tuning (ignored for SQLite).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600

# --- Authentication & security ---------------------------------------------
# Must be at least 32 bytes of random data. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRE_MINUTES=30

# Set to "false" only for local HTTP development. Keep "true" in production (HTTPS).
AUTH_COOKIE_SECURE=true

# Optional dedicated pepper for hashing IP addresses in audit logs.
# Falls back to JWT_SECRET if unset.
# IP_HASH_PEPPER=change-me-to-a-separate-random-value

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed front-end origins. "*" is not permitted.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Rate limiting ----------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
PUBLIC_RATE_LIMIT=60
PUBLIC_RATE_WINDOW_SECONDS=60

# --- Frontend (frontend/.env) ----------------------------------------------
# Base URL the SPA uses to reach the API. Defaults to "/api" (proxied by Vite).
# VITE_API_URL=/api
